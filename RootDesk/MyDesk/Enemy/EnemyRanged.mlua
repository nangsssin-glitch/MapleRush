@Component
script EnemyRanged extends Component

	property number DetectRadius = 5.0

	property number AimTime = 1.0

	property number FireCooldown = 1.0

	property boolean ProjectileParryable = true

	-- aim / cooldown (감지 중에만 사이클 진행; 이동은 병행)
	property string cyclePhase = "aim"

	property number cycleTimer = 0.0

	-- 클라 기즈모용: aim(조준 캐스팅) 단계 동안 true. 원거리 예상 레인 표시 트리거.
	@Sync property boolean IsAiming = false

	-- 조준 시작(결정 시점) 1회 고정되는 발사 방향. 플레이어가 움직여도 추적하지 않음(회피 가능). 발사·기즈모 공용(@Sync).
	@Sync property number AimDirX = 0
	@Sync property number AimDirY = 0
	property boolean aimLocked = false

	property integer shotIndex = 0

	-- 모션 구동: 모델 기본 SpriteRUID(stand) 캡처 후 상태별 교체.
	property string standClip = ""

	property string currentClip = ""

	-- 엔티티별 클립셋(EnemyAnimSet, 인스펙터 편집). 없거나 미지정이면 GameConstants 폴백.
	property any animSet = nil

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 조준 사이클 초기화 + 클립셋 캐시 + stand 캡처(AnimSet StandClip 있으면 override).
		self.cyclePhase = "aim"
		self.cycleTimer = self.AimTime
		self.animSet = self.Entity:GetComponent("script.EnemyAnimSet")
		local sprite = self.Entity.SpriteRendererComponent
		if isvalid(sprite) then self.standClip = sprite.SpriteRUID end
		self.standClip = self:AnimClip("idle", self.standClip)
		self.currentClip = self.standClip
	end

	method string AnimClip(string key, string fallback)
		-- EnemyAnimSet에서 key 클립 조회. 컴포넌트 없거나 미지정("")이면 fallback(GameConstants).
		if self.animSet ~= nil then
			---@type EnemyAnimSet
			local a = self.animSet
			local r = a:Clip(key)
			if r ~= "" then return r end
		end
		return fallback
	end

	@ExecSpace("ServerOnly")
	method void PlayClip(string ruid)
		-- SpriteRUID 교체(변경 시에만 — 매 프레임 재set 시 애니 0프레임 정지 방지). @Sync라 클라 자동 반영.
		if ruid == "" or ruid == self.currentClip then return end
		local sprite = self.Entity.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = ruid
			self.currentClip = ruid
		end
	end

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		-- 원거리 적 AI: 감지(5) 내 플레이어를 향해 이동하며 조준 1s → 발사 1발 → 쿨 1s 반복. 감지 이탈 시 조준 취소.
		---@type EnemyHealth
		local hp = self.Entity:GetComponent("script.EnemyHealth")
		if hp ~= nil and hp.IsDead == true then self.IsAiming = false self.aimLocked = false self:PlayClip(self:AnimClip("die", self.standClip)) return end
		if _StageManager:IsGraceActive() then
			self.IsAiming = false
			self.aimLocked = false
			self:StopMove()
			self:PlayClip(self.standClip)
			return
		end
		-- 섬광탄 기절: 이동·조준·발사 정지
		if _BattlefieldFx:IsStunActive() then
			self.IsAiming = false
			self.aimLocked = false
			self:StopMove()
			self:PlayClip(self.standClip)
			return
		end
		-- 피격(HIT): 조준 취소(발사 안 함) → 공격이 멈춘다. hit 모션(없으면 idle). 윈도우 후 조준 새로 시작.
		if hp ~= nil and _UtilLogic.ServerElapsedSeconds < hp.hitClipUntil then
			self.IsAiming = false
			self.aimLocked = false
			self.cyclePhase = "aim"
			self.cycleTimer = self.AimTime
			self:StopMove()
			self:PlayClip(self:AnimClip("hit", self.standClip))
			return
		end
		local timeScale = _SlowMotion:Scale()
		local scaledDelta = delta * timeScale
		local player = self:FindPlayer()
		-- 연막탄 은신: 플레이어가 연막 구름(반경3) 안에 있으면 감지/조준 해제 → 조준 사이클 리셋. 구름 밖이면 다시 들킴.
		if player ~= nil then
			local spp = player.TransformComponent.WorldPosition
			if _BattlefieldFx:IsSmokeHiding(Vector2(spp.x, spp.y + _GameConstants.PlayerCenterYOffset)) then
				self.IsAiming = false
				self.aimLocked = false
				self.cyclePhase = "aim"
				self.cycleTimer = self.AimTime
				self:StopMove()
				self:PlayClip(self.standClip)
				return
			end
		end
		if player == nil then
			self.IsAiming = false
			self.aimLocked = false
			self:StopMove()
			self:PlayClip(self.standClip)
			return
		end
		local myPos = self.Entity.TransformComponent.WorldPosition
		local pp = player.TransformComponent.WorldPosition
		local playerCenter = Vector2(pp.x, pp.y + 0.5)
		local myCenter = Vector2(myPos.x, myPos.y + 0.5)
		local dx = playerCenter.x - myCenter.x
		local dy = playerCenter.y - myCenter.y
		local dist = math.sqrt(dx * dx + dy * dy)

		if dist > self.DetectRadius then
			-- 감지 이탈: 조준 취소 후 대기
			if self.cyclePhase == "aim" and self.cycleTimer < self.AimTime then
				log("[EnemyRanged] aim canceled (player out of range)")
			end
			self.IsAiming = false
			self.aimLocked = false
			self.cyclePhase = "aim"
			self.cycleTimer = self.AimTime
			self:StopMove()
			self:PlayClip(self.standClip)
			return
		end

		-- 조준(aim) 중엔 정지 캐스팅, 쿨다운엔 플레이어 방향 이동 (걸으며 캐스팅 방지)
		if self.cyclePhase == "aim" then
			self:StopMove()
		else
			self:ChaseToward(playerCenter.x, myCenter.x, timeScale, delta)
		end

		-- 조준/발사 사이클
		self.cycleTimer -= scaledDelta
		if self.cycleTimer <= 0 then
			if self.cyclePhase == "aim" then
				self:Fire(playerCenter, myCenter)
				self.cyclePhase = "cooldown"
				self.cycleTimer = self.FireCooldown
			else
				self.cyclePhase = "aim"
				self.cycleTimer = self.AimTime
			end
		end

		-- 조준 단계 동기화 + 발사 방향 고정. 조준 첫 프레임에 방향을 잠가(플레이어 추적 금지) 발사·기즈모 공용.
		if self.cyclePhase == "aim" then
			self.IsAiming = true
			if self.aimLocked == false then
				local d = _CombatPrimitives:DirectionTo(myCenter, playerCenter)
				self.AimDirX = d.x
				self.AimDirY = d.y
				self.aimLocked = true
				log("[EnemyRanged] aim LOCKED dir=(" .. string.format("%.2f", d.x) .. "," .. string.format("%.2f", d.y) .. ")")
			end
		else
			self.IsAiming = false
			self.aimLocked = false
		end

		-- 모션: 조준(aim, 1s 캐스팅) 단계에 공격 클립 → 발사 직전까지 잘 보임. 쿨다운(발사 후)엔 move로 복귀.
		if self.cyclePhase == "aim" then
			self:PlayClip(self:AnimClip("attack", _GameConstants.RangedAttackClip))
		else
			self:PlayClip(self:AnimClip("run", _GameConstants.RangedMoveClip))
		end
	end

	@ExecSpace("ServerOnly")
	method void Fire(Vector2 targetCenter, Vector2 fromCenter)
		-- 조준 시작 시 고정된 방향으로 직선 투사체 1발(유도·추적 없음). 미고정 시에만 현재 타깃으로 폴백.
		local map = self.Entity.CurrentMap
		if isvalid(map) == false then return end
		self.shotIndex += 1
		local dir = Vector2(self.AimDirX, self.AimDirY)
		if self.aimLocked == false then
			dir = _CombatPrimitives:DirectionTo(fromCenter, targetCenter)
		end
		local spawnPos = Vector3(fromCenter.x + dir.x * 0.4, fromCenter.y + dir.y * 0.4, 0)
		local name = self.Entity.Name .. "_proj_" .. tostring(self.shotIndex)
		local proj = _SpawnService:SpawnByModelId("enemyprojectile", name, spawnPos, map)
		if proj == nil then
			log_error("[EnemyRanged] SpawnByModelId('enemyprojectile') returned nil")
			return
		end
		---@type Projectile
		local comp = proj:GetComponent("script.Projectile")
		if comp ~= nil then
			comp:Launch(dir.x, dir.y, _GameConstants.ProjectileSpeed, 1, self.ProjectileParryable)
			log("[EnemyRanged] " .. self.Entity.Name .. " fired projectile dir=(" .. string.format("%.2f", dir.x) .. "," .. string.format("%.2f", dir.y) .. ")")
		end
	end

	@ExecSpace("ServerOnly")
	method Entity FindPlayer()
		-- 같은 맵의 첫 번째 유효 플레이어 반환.
		local map = self.Entity.CurrentMap
		if isvalid(map) == false then return nil end
		local users = _UserService:GetUsersByMapComponent(map.MapComponent)
		if users == nil then return nil end
		for _, u in ipairs(users) do
			if isvalid(u) then return u end
		end
		return nil
	end

	-- 맵 타입 캐시: 0=미해석 / 1=SideView / 2=MapleTile.
	@HideFromInspector
	property integer mapKindCache = 0

	@ExecSpace("ServerOnly")
	method boolean IsSideViewMap()
		-- 현재 맵이 RectTile/SideView인지. 결과 캐시 → 매 프레임 child 탐색 방지.
		if self.mapKindCache == 0 then
			local map = self.Entity.CurrentMap
			if isvalid(map) == false then return false end
			if isvalid(map:GetFirstChildComponentByTypeName("MOD.Core.RectTileMapComponent", true)) then
				self.mapKindCache = 1
			else
				self.mapKindCache = 2
			end
		end
		return self.mapKindCache == 1
	end

	@ExecSpace("ServerOnly")
	method void ChaseToward(number targetX, number myX, number timeScale, number delta)
		-- 추격 이동. SideView=MovementComponent:MoveToDirection / MapleTile=Rigidbody.MoveVelocity(+풋홀드 낭떠러지 정지).
		local dir = 1
		if targetX < myX then dir = -1 end
		local map = self.Entity.CurrentMap
		if self:IsSideViewMap() then
			-- SideView/RectTile
			local svb = self.Entity.SideviewbodyComponent
			if isvalid(svb) == false or svb:IsOnGround() == false then return end
			local mc = self.Entity.MovementComponent
			if isvalid(mc) == false then return end
			mc.InputSpeed = _GameConstants.EnemyChaseSpeed * timeScale
			mc:MoveToDirection(Vector2(dir, 0), delta)
		else
			-- MapleTile (기존 로직 유지)
			local rb = self.Entity.RigidbodyComponent
			if isvalid(rb) == false or rb:IsOnGround() == false then return end
			if isvalid(map) and isvalid(map.FootholdComponent) then
				local pos = self.Entity.TransformComponent.WorldPosition
				local probe = Vector2(pos.x + dir * 0.5, pos.y + 0.3)
				local ground = map.FootholdComponent:Raycast(probe, Vector2(0, -1), 1.0)
				if ground == nil then
					self:StopMove()
					return
				end
			end
			rb.MoveVelocity = Vector2(dir * timeScale, 0)
		end
		-- 스프라이트는 좌향 기본 → 우측 이동 시 FlipX
		local sprite = self.Entity.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.FlipX = dir > 0
		end
	end

	@ExecSpace("ServerOnly")
	method void StopMove()
		-- 이동 정지(양 모드).
		local mc = self.Entity.MovementComponent
		if isvalid(mc) then mc:Stop() end
		local rb = self.Entity.RigidbodyComponent
		if isvalid(rb) then rb.MoveVelocity = Vector2(0, 0) end
	end

end
