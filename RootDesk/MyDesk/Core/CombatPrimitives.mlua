@Logic
script CombatPrimitives extends Logic

	-- 서버측 활성 적 공격 레코드 목록 (F5 공격 데이터 모델)
	property any activeAttacks = nil

	property integer nextAttackId = 0

	-- 대시 방-영역(RoomRegion) 캐시 — 조준 중 매 프레임 호출되므로 맵별 1회만 마커 열거 후 캐시 (클라).
	property any roomCacheMapName = nil

	property any roomCacheRegions = nil

	-- 대시 블록(DashBlock) 콜라이더 캐시 — 전체 열거 클램프용(맵별 1회). Raycast 첫-히트 한계 회피.
	property any blockColliderCacheMapName = nil

	property any blockColliderCache = nil

	-- 클라측 수신 적 근접 공격 원 목록(전투 기즈모 표시 전용). 항목 {id,center,radius,parryable,windup,life,recvAt}. CombatGizmo가 카운트다운·제거.
	property any clientEnemyAttacks = nil

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		-- 만료된 공격 레코드 정리 (서버, 매 프레임).
		if self.activeAttacks == nil then return end
		local now = _UtilLogic.ServerElapsedSeconds
		for i = #self.activeAttacks, 1, -1 do
			if self.activeAttacks[i].expireAt < now then
				table.remove(self.activeAttacks, i)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method table RegisterEnemyAttackBox(Vector2 boxCenter, number hw, number hh, number damage, boolean parryable, number hitDelay, Entity sourceEntity)
		-- 적 공격 박스 레코드 등록(서버). hitDelay(텔레그래프) 후 명중 판정, 직후 만료. 반환: 레코드 테이블.
		-- boxCenter/hw/hh는 호출부가 전방/중앙 기하로 계산해 넘김(프리미티브는 AABB만 저장).
		-- sourceEntity: 공격 주체 적(맵/유저 산출용 — 기즈모 브로드캐스트 대상). 판정 로직엔 미사용(무손상).
		if self.activeAttacks == nil then self.activeAttacks = {} end
		self.nextAttackId += 1
		local now = _UtilLogic.ServerElapsedSeconds
		local rec = {
			id = self.nextAttackId,
			shape = "box",
			center = boxCenter,
			hw = hw,
			hh = hh,
			radius = 0,
			damage = damage,
			parryable = parryable,
			hitAt = now + hitDelay,
			expireAt = now + hitDelay + 0.25,
			canceled = false,
			-- 보스 패턴이 BossController에서 주입(평타/일반적은 nil). TryParry가 그로기 충전 대상 판별에 사용.
			bossEntityId = nil,
		}
		table.insert(self.activeAttacks, rec)
		-- 기즈모 통지: 남은 windup=hitDelay, 남은 life=hitDelay+0.25(=expireAt-now). 절대 ServerElapsedSeconds 누수 금지 — 상대초만.
		self:BroadcastEnemyAttack(sourceEntity, rec.id, boxCenter, hw, hh, hitDelay, hitDelay + 0.25, parryable)
		return rec
	end

	method boolean RecordOverlapsCircle(table rec, Vector2 circleCenter, number r)
		-- 공격 레코드 vs 원 디스패처. 현 레코드는 전부 box지만 안전하게 circle도 처리.
		if rec.shape == "box" then
			return self:BoxCircleOverlap(rec.center, rec.hw, rec.hh, circleCenter, r)
		end
		return self:CircleOverlap(rec.center, rec.radius, circleCenter, r)
	end

	method boolean RecordOverlapsBox(table rec, Vector2 boxCenter, number hw, number hh)
		-- 공격 레코드 vs 박스 디스패처(피격자=박스 hurtbox). box 레코드=박스-박스 / circle 레코드=박스-원.
		if rec.shape == "box" then
			return self:BoxBoxOverlap(rec.center, rec.hw, rec.hh, boxCenter, hw, hh)
		end
		return self:BoxCircleOverlap(boxCenter, hw, hh, rec.center, rec.radius)
	end

	@ExecSpace("ServerOnly")
	method boolean AnyThreatNear(Entity mapEntity, Vector2 center, number radius)
		-- 슬로우 모션 트리거 판정: 활성 적 공격 레코드 또는 적 투사체가 radius 내 존재하는지 (서버).
		if self.activeAttacks ~= nil then
			for _, rec in ipairs(self.activeAttacks) do
				if rec.canceled == false and self:RecordOverlapsCircle(rec, center, radius) then
					return true
				end
			end
		end
		if mapEntity ~= nil then
			local list = mapEntity:GetChildComponentsByTypeName("script.Projectile", true)
			for _, compAny in ipairs(list) do
				---@type Projectile
				local comp = compAny
				local e = comp.Entity
				if isvalid(e) and comp.OwnerSide == "enemy" then
					local p = e.TransformComponent.WorldPosition
					if self:CircleOverlap(center, radius, Vector2(p.x, p.y), _GameConstants.RadiusProjectile) then
						return true
					end
				end
			end
		end
		return false
	end

	@ExecSpace("ServerOnly")
	method integer TryParry(Entity mapEntity, Vector2 boxCenter, number hw, number hh, number reflectDamage)
		-- 평타 판정 박스와 겹치는 parryable 공격 처리: 근접 공격 무효화 / 투사체 반사(ATK×200%). 반환: 패링 수.
		local count = 0
		-- 근접 패링 윈도우(§1.4): 명중시점 hitAt 기준 선행 Lead·후행 Trail 안에서만 성립. now/hitAt 모두 ServerElapsedSeconds.
		local now = _UtilLogic.ServerElapsedSeconds
		local parryLead = _GameConstants.ParryWindowLead
		local parryTrail = _GameConstants.ParryWindowTrail
		if self.activeAttacks ~= nil then
			for _, rec in ipairs(self.activeAttacks) do
				if rec.canceled == false and rec.parryable and self:BoxBoxOverlap(boxCenter, hw, hh, rec.center, rec.hw, rec.hh) then
					if now >= rec.hitAt - parryLead and now <= rec.hitAt + parryTrail then
						rec.canceled = true
						count += 1
						self:BroadcastCancel(mapEntity, rec.id)
						log("[CombatPrimitives] melee attack PARRIED (id=" .. tostring(rec.id) .. ", dt=" .. tostring(now - rec.hitAt) .. ")")
						-- 보스 근거리 패링: 그로기 게이지 즉시 (ATK×100%)×2 충전 (stage_design §1.4.2)
						if rec.bossEntityId ~= nil and mapEntity ~= nil then
							local bossEntity = mapEntity:GetChildByName(rec.bossEntityId, true)
							if isvalid(bossEntity) then
								---@type GroggyGauge
								local gg = bossEntity:GetComponent("script.GroggyGauge")
								if gg ~= nil then
									gg:Charge(_GameStateManager.AttackStat * _GameConstants.GroggyParryMult, "parry")
								end
							end
						end
					else
						-- 윈도우 밖(너무 이르거나 늦음) → 패링 미성립. 공격은 그대로 진행(회피 필요).
						log("[CombatPrimitives] melee parry MISTIMED (id=" .. tostring(rec.id) .. ", dt=" .. tostring(now - rec.hitAt) .. ")")
					end
				end
			end
		end
		if mapEntity ~= nil then
			local list = mapEntity:GetChildComponentsByTypeName("script.Projectile", true)
			for _, compAny in ipairs(list) do
				---@type Projectile
				local comp = compAny
				local e = comp.Entity
				if isvalid(e) and comp.OwnerSide == "enemy" and comp.Parryable == true then
					local p = e.TransformComponent.WorldPosition
					if self:BoxCircleOverlap(boxCenter, hw, hh, Vector2(p.x, p.y), _GameConstants.RadiusProjectile) then
						comp:Reflect(reflectDamage)
						count += 1
						log("[CombatPrimitives] projectile REFLECTED (dmg=" .. tostring(reflectDamage) .. ")")
					end
				end
			end
		end
		return count
	end

	method boolean CircleOverlap(Vector2 centerA, number radiusA, Vector2 centerB, number radiusB)
		-- 단일 원형 오버랩 유틸 (V4 실측 확정: dist <= r1+r2). 모든 범위 판정은 이 함수만 사용.
		local dx = centerB.x - centerA.x
		local dy = centerB.y - centerA.y
		local r = radiusA + radiusB
		return dx * dx + dy * dy <= r * r
	end

	method boolean BoxCircleOverlap(Vector2 boxCenter, number hw, number hh, Vector2 circleCenter, number r)
		-- AABB(중심 boxCenter, 반폭 hw, 반높이 hh) vs 원(circleCenter, r). 원 중심을 박스에 클램프한 최근접점 거리 ≤ r.
		local nx = circleCenter.x
		local minx = boxCenter.x - hw
		local maxx = boxCenter.x + hw
		if nx < minx then nx = minx elseif nx > maxx then nx = maxx end
		local ny = circleCenter.y
		local miny = boxCenter.y - hh
		local maxy = boxCenter.y + hh
		if ny < miny then ny = miny elseif ny > maxy then ny = maxy end
		local dx = circleCenter.x - nx
		local dy = circleCenter.y - ny
		return dx * dx + dy * dy <= r * r
	end

	method boolean BoxBoxOverlap(Vector2 aCenter, number aHw, number aHh, Vector2 bCenter, number bHw, number bHh)
		-- AABB-AABB. 두 박스 중심 거리가 각 축 반폭/반높이 합 이내면 겹침.
		return math.abs(aCenter.x - bCenter.x) <= (aHw + bHw) and math.abs(aCenter.y - bCenter.y) <= (aHh + bHh)
	end

	method any HurtboxOf(Entity e, number fbHW, number fbHH, number fbYOff)
		-- 엔티티 hurtbox 박스 {cx,cy,hw,hh}. HitComponent(Box) 있으면 BoxSize×Scale + ColliderOffset 사용(=Maker 인스펙터에서 편집).
		-- 없으면 폴백: 반폭/반높이=상수, 중심=transform 좌표 + fbYOff(적=0 raw / 플레이어=PlayerCenterYOffset 0.5).
		-- 적 모델엔 HitComponent 있음. 플레이어(DefaultPlayer=Global)는 Maker에서 수동 추가 시 인스펙터 편집, 없으면 폴백 상수.
		local p = e.TransformComponent.WorldPosition
		local hc = e.HitComponent
		if isvalid(hc) and hc.BoxSize.x > 0 and hc.BoxSize.y > 0 then
			local sc = e.TransformComponent.Scale
			local bs = hc.BoxSize
			local off = hc.ColliderOffset
			-- 반폭/반높이는 절대값(몬스터 좌우반전 = Scale.x 음수여도 박스 크기는 양수 유지). 중심 오프셋은 부호 유지(반전 시 미러).
			return { cx = p.x + off.x * sc.x, cy = p.y + off.y * sc.y, hw = bs.x * math.abs(sc.x) * 0.5, hh = bs.y * math.abs(sc.y) * 0.5 }
		end
		return { cx = p.x, cy = p.y + fbYOff, hw = fbHW, hh = fbHH }
	end

	method table MakeAttack(Vector2 center, number radius, number damage, boolean parryable, string ownerSide)
		-- 공통 공격 데이터 구조 (F5). 플레이어/적/투사체/아이템 공격 전부 이 구조로 표현.
		return {
			center = center,
			radius = radius,
			damage = damage,
			parryable = parryable,
			ownerSide = ownerSide,
		}
	end

	method Vector2 DirectionTo(Vector2 fromPos, Vector2 toPos)
		-- fromPos → toPos 정규화 방향 벡터. 영벡터면 (1,0) 반환.
		local d = Vector2(toPos.x - fromPos.x, toPos.y - fromPos.y)
		if d.x == 0 and d.y == 0 then
			return Vector2(1, 0)
		end
		return d:Normalize()
	end

	method number PointSegmentDistance(Vector2 point, Vector2 segStart, Vector2 segEnd)
		-- point에서 선분 segStart-segEnd까지의 최단 거리.
		local vx = segEnd.x - segStart.x
		local vy = segEnd.y - segStart.y
		local wx = point.x - segStart.x
		local wy = point.y - segStart.y
		local lenSq = vx * vx + vy * vy
		local t = 0.0
		if lenSq > 0 then
			t = (wx * vx + wy * vy) / lenSq
			if t < 0 then t = 0 elseif t > 1 then t = 1 end
		end
		local cx = segStart.x + vx * t
		local cy = segStart.y + vy * t
		local dx = point.x - cx
		local dy = point.y - cy
		return math.sqrt(dx * dx + dy * dy)
	end

	method boolean SegmentBoxOverlap(Vector2 segStart, Vector2 segEnd, Vector2 boxCenter, number hw, number hh, number radius)
		-- 선분+반경(캡슐) vs AABB 박스. 박스 중심에 가장 가까운 선분 위 점을 구해 그 점(반경 radius 원)이 박스와 겹치는지로 근사.
		-- (얇은 대시 경로엔 충분. 정확한 코너 케이스는 무시 — 박스 hurtbox 통일용.)
		local vx = segEnd.x - segStart.x
		local vy = segEnd.y - segStart.y
		local wx = boxCenter.x - segStart.x
		local wy = boxCenter.y - segStart.y
		local lenSq = vx * vx + vy * vy
		local t = 0.0
		if lenSq > 0 then
			t = (wx * vx + wy * vy) / lenSq
			if t < 0 then t = 0 elseif t > 1 then t = 1 end
		end
		local cx = segStart.x + vx * t
		local cy = segStart.y + vy * t
		return self:BoxCircleOverlap(boxCenter, hw, hh, Vector2(cx, cy), radius)
	end

	method integer DamageEnemiesInCircle(Entity mapEntity, Vector2 center, number radius, number damage, string source)
		-- 원형 범위 내 모든 적(script.EnemyHealth)에 데미지. 명중 수 반환. 서버 메서드에서 호출할 것.
		if mapEntity == nil then return 0 end
		local list = mapEntity:GetChildComponentsByTypeName("script.EnemyHealth", true)
		local hitCount = 0
		for _, compAny in ipairs(list) do
			---@type EnemyHealth
			local comp = compAny
			local e = comp.Entity
			if isvalid(e) then
				local hb = self:HurtboxOf(e, _GameConstants.EnemyHboxHW, _GameConstants.EnemyHboxHH, 0)
				if self:BoxCircleOverlap(Vector2(hb.cx, hb.cy), hb.hw, hb.hh, center, radius) then
					comp:TakeDamage(damage, source)
					hitCount += 1
				end
			end
		end
		return hitCount
	end

	method integer DamageEnemiesInBox(Entity mapEntity, Vector2 boxCenter, number hw, number hh, number damage, string source)
		-- 박스 범위 내 모든 적(script.EnemyHealth)에 데미지. 명중 수 반환. 서버 메서드에서 호출할 것.
		if mapEntity == nil then return 0 end
		local list = mapEntity:GetChildComponentsByTypeName("script.EnemyHealth", true)
		local hitCount = 0
		for _, compAny in ipairs(list) do
			---@type EnemyHealth
			local comp = compAny
			local e = comp.Entity
			if isvalid(e) then
				local hb = self:HurtboxOf(e, _GameConstants.EnemyHboxHW, _GameConstants.EnemyHboxHH, 0)
				if self:BoxBoxOverlap(boxCenter, hw, hh, Vector2(hb.cx, hb.cy), hb.hw, hb.hh) then
					comp:TakeDamage(damage, source)
					hitCount += 1
				end
			end
		end
		return hitCount
	end

	method integer DamageEnemiesAlongPath(Entity mapEntity, Vector2 pathStart, Vector2 pathEnd, number pathRadius, number damage, string source)
		-- 대시 이동 경로(선분 + 반경) 위의 모든 적에 데미지. 명중 수 반환. 서버 메서드에서 호출할 것.
		if mapEntity == nil then return 0 end
		local list = mapEntity:GetChildComponentsByTypeName("script.EnemyHealth", true)
		local hitCount = 0
		for _, compAny in ipairs(list) do
			---@type EnemyHealth
			local comp = compAny
			local e = comp.Entity
			if isvalid(e) then
				local hb = self:HurtboxOf(e, _GameConstants.EnemyHboxHW, _GameConstants.EnemyHboxHH, 0)
				if self:SegmentBoxOverlap(pathStart, pathEnd, Vector2(hb.cx, hb.cy), hb.hw, hb.hh, pathRadius) then
					comp:TakeDamage(damage, source)
					hitCount += 1
				end
			end
		end
		return hitCount
	end

	method table BuildRoomRegions(Entity map)
		-- 맵에 배치된 RoomRegionMarker 컴포넌트를 열거해 영역 목록 생성. (캐시 미스 시 1회 호출)
		-- 영역 = 같은 엔티티의 TriggerComponent 콜라이더. BoxSize=방 가로/세로(월드유닛), ColliderOffset=중심 오프셋.
		-- IsLegacy=false 콜라이더는 Transform 크기 영향을 받으므로 BoxSize×Scale로 실제 박스를 복원.
		local regions = {}
		if map == nil or isvalid(map) == false then return regions end
		local markers = map:GetChildComponentsByTypeName("script.RoomRegionMarker", true)
		if markers ~= nil then
			for _, compAny in ipairs(markers) do
				local e = compAny.Entity
				if isvalid(e) then
					local tc = e.TriggerComponent
					local tf = e.TransformComponent
					if isvalid(tc) and isvalid(tf) then
						local p = tf.WorldPosition
						local sc = tf.Scale
						local sz = tc.BoxSize
						local off = tc.ColliderOffset
						table.insert(regions, {
							kind = "rect",
							cx = p.x + off.x * sc.x,
							cy = p.y + off.y * sc.y,
							halfW = sz.x * sc.x * 0.5,
							halfH = sz.y * sc.y * 0.5,
						})
					end
				end
			end
		end
		return regions
	end

	method boolean RegionContains(table region, Vector2 point)
		-- 점이 영역 안에 있는지. (rect=AABB 포함 판정. 추후 kind="poly" 분기 추가 가능)
		if region.kind == "rect" then
			return point.x >= region.cx - region.halfW and point.x <= region.cx + region.halfW
				and point.y >= region.cy - region.halfH and point.y <= region.cy + region.halfH
		end
		return false
	end

	method number RegionClampRay(table region, Vector2 origin, Vector2 dir, number maxLen)
		-- origin에서 dir 방향으로 영역을 처음 벗어나는 거리와 maxLen 중 작은 값. (rect=슬랩)
		if region.kind == "rect" then
			local tx = math.huge
			if dir.x > 0 then tx = (region.cx + region.halfW - origin.x) / dir.x
			elseif dir.x < 0 then tx = (region.cx - region.halfW - origin.x) / dir.x end
			local ty = math.huge
			if dir.y > 0 then ty = (region.cy + region.halfH - origin.y) / dir.y
			elseif dir.y < 0 then ty = (region.cy - region.halfH - origin.y) / dir.y end
			local exitDist = math.min(tx, ty)
			if exitDist < 0 then exitDist = 0 end
			if exitDist < maxLen then return exitDist end
		end
		return maxLen
	end

	method number OBBRayEntry(any hitComp, Vector2 origin, Vector2 dir, number maxLen)
		-- raycast로 맞은 블록 콜라이더 박스에 레이가 처음 '진입'하는 거리(슬랩 tmin). 회전 박스(OBB) 지원.
		-- 박스 = 같은 엔티티의 TriggerComponent(BoxSize/ColliderOffset) + Transform(WorldPosition/Scale/WorldZRotation).
		-- origin이 박스 안(tmin<0)이면 0(즉시 정지), 박스가 뒤/빗나감이면 maxLen(무시).
		if hitComp == nil then return maxLen end
		local e = hitComp.Entity
		if isvalid(e) == false then return maxLen end
		local tc = e.TriggerComponent
		local tf = e.TransformComponent
		if isvalid(tc) == false or isvalid(tf) == false then return maxLen end
		local p = tf.WorldPosition
		local sc = tf.Scale
		local sz = tc.BoxSize
		local off = tc.ColliderOffset
		local a = math.rad(tf.WorldZRotation)
		local ca = math.cos(a)
		local sa = math.sin(a)
		-- 박스 중심(월드): ColliderOffset도 박스 회전을 따라 회전
		local oxw = off.x * sc.x
		local oyw = off.y * sc.y
		local cx = p.x + (oxw * ca - oyw * sa)
		local cy = p.y + (oxw * sa + oyw * ca)
		local halfW = sz.x * sc.x * 0.5
		local halfH = sz.y * sc.y * 0.5
		-- 레이를 박스 로컬좌표로 변환(중심 빼고 -a 회전)
		local rx = origin.x - cx
		local ry = origin.y - cy
		local lox = rx * ca + ry * sa
		local loy = -rx * sa + ry * ca
		local ldx = dir.x * ca + dir.y * sa
		local ldy = -dir.x * sa + dir.y * ca
		local EPS = 0.00000001
		local tmin = -math.huge
		local tmax = math.huge
		if math.abs(ldx) < EPS then
			if lox < -halfW or lox > halfW then return maxLen end
		else
			local t1 = (-halfW - lox) / ldx
			local t2 = (halfW - lox) / ldx
			if t1 > t2 then local tmp = t1 t1 = t2 t2 = tmp end
			if t1 > tmin then tmin = t1 end
			if t2 < tmax then tmax = t2 end
		end
		if math.abs(ldy) < EPS then
			if loy < -halfH or loy > halfH then return maxLen end
		else
			local t1 = (-halfH - loy) / ldy
			local t2 = (halfH - loy) / ldy
			if t1 > t2 then local tmp = t1 t1 = t2 t2 = tmp end
			if t1 > tmin then tmin = t1 end
			if t2 < tmax then tmax = t2 end
		end
		if tmax < 0 or tmin > tmax then return maxLen end
		local entry = tmin
		if entry < 0 then entry = 0 end
		if entry < maxLen then return entry end
		return maxLen
	end

	method number BlockClampEntry(any hitComp, Vector2 origin, Vector2 dir, number maxLen, number wallMargin)
		-- 방향성 블록 클램프 거리. 회전(OBB) 지원.
		-- origin이 블록 '밖'이면 진입거리(슬랩 tmin) → 벽 앞에서 정지(진입 불가). 빗나가면 maxLen.
		--   진입 면이 측면(x축=벽)이면 wallMargin만큼 더 앞에서 정지(플레이어가 벽에 안 박히게). 위/아래 면(y축)은 마진 미적용.
		-- origin이 블록 '안'이면: 가장 가까운 면의 바깥 노멀과 dir 내적>0(바깥으로 탈출)이면 maxLen(무시=탈출 허용),
		--   아니면(안쪽/면과 평행) 0 → 더 깊이 못 들어감. (벽 겹침 시 바깥으로만 이동 허용)
		if hitComp == nil then return maxLen end
		local e = hitComp.Entity
		if isvalid(e) == false then return maxLen end
		local tc = e.TriggerComponent
		local tf = e.TransformComponent
		if isvalid(tc) == false or isvalid(tf) == false then return maxLen end
		local p = tf.WorldPosition
		local sc = tf.Scale
		local sz = tc.BoxSize
		local off = tc.ColliderOffset
		local a = math.rad(tf.WorldZRotation)
		local ca = math.cos(a)
		local sa = math.sin(a)
		local oxw = off.x * sc.x
		local oyw = off.y * sc.y
		local cx = p.x + (oxw * ca - oyw * sa)
		local cy = p.y + (oxw * sa + oyw * ca)
		local halfW = sz.x * sc.x * 0.5
		local halfH = sz.y * sc.y * 0.5
		-- origin/dir → 박스 로컬좌표
		local rx = origin.x - cx
		local ry = origin.y - cy
		local lox = rx * ca + ry * sa
		local loy = -rx * sa + ry * ca
		local ldx = dir.x * ca + dir.y * sa
		local ldy = -dir.x * sa + dir.y * ca
		local EPS = 0.0001
		local inside = lox > -halfW + EPS and lox < halfW - EPS and loy > -halfH + EPS and loy < halfH - EPS
		if inside then
			-- 가장 가까운 면의 바깥 노멀(로컬)
			local px = halfW - math.abs(lox)
			local py = halfH - math.abs(loy)
			local nx = 0.0
			local ny = 0.0
			if px <= py then
				if lox >= 0 then nx = 1.0 else nx = -1.0 end
			else
				if loy >= 0 then ny = 1.0 else ny = -1.0 end
			end
			if ldx * nx + ldy * ny > 0 then return maxLen end
			return 0
		end
		-- 밖: 슬랩 진입거리. 면과 평행하면서 그 면 바깥/경계면 빗나감(maxLen). 진입 면 축도 추적(측면=x면 마진용).
		local tmin = -math.huge
		local tmax = math.huge
		local entrySide = false
		if math.abs(ldx) < EPS then
			if lox <= -halfW + EPS or lox >= halfW - EPS then return maxLen end
		else
			local t1 = (-halfW - lox) / ldx
			local t2 = (halfW - lox) / ldx
			if t1 > t2 then local tmp = t1 t1 = t2 t2 = tmp end
			if t1 > tmin then tmin = t1 entrySide = true end
			if t2 < tmax then tmax = t2 end
		end
		if math.abs(ldy) < EPS then
			if loy <= -halfH + EPS or loy >= halfH - EPS then return maxLen end
		else
			local t1 = (-halfH - loy) / ldy
			local t2 = (halfH - loy) / ldy
			if t1 > t2 then local tmp = t1 t1 = t2 t2 = tmp end
			if t1 > tmin then tmin = t1 entrySide = false end
			if t2 < tmax then tmax = t2 end
		end
		if tmax < 0 or tmin > tmax then return maxLen end
		local entry = tmin
		if entry < 0 then entry = 0 end
		if entry >= maxLen then return maxLen end
		-- 측면(벽) 진입에만 마진 적용 — 위/아래(바닥·천장)는 착지 스냅이 담당.
		if entrySide and wallMargin > 0 then
			entry = entry - wallMargin
			if entry < 0 then entry = 0 end
		end
		return entry
	end

	method number ClampRayToCurrentRoom(Entity map, Vector2 playerPos, Vector2 origin, Vector2 dir, number maxDist, number blockGrace)
		-- 대시 거리 클램프. result=maxDist에서 시작해 (1) allow-box 논리 영역, (2) 블록 존 raycast 중 더 가까운 곳으로 줄임.
		-- 둘 다 없으면 maxDist 그대로(폴백 = 기존 최대 사거리, 안전).
		-- blockGrace: 접지 시 블록 ray 원점 Y를 이만큼 올림(스텝오버 — 낮은 장애물 통과). 공중=0(원점 그대로).
		--   벽 겹침 처리는 BlockClampEntry가 방향성으로: 밖이면 벽 앞 정지(진입 불가), 안이면 바깥 방향만 탈출 허용·안쪽은 0.
		--   allow-box는 영향 없음.
		if map == nil or isvalid(map) == false then return maxDist end
		local result = maxDist
		-- (1) allow-box(감싸는 방) 논리 클램프 — 플레이어를 포함하는 방의 경계 이탈거리. 마커 열거는 맵별 1회 캐시.
		if self.roomCacheMapName ~= map.Name then
			self.roomCacheRegions = self:BuildRoomRegions(map)
			self.roomCacheMapName = map.Name
		end
		local regions = self.roomCacheRegions
		if regions ~= nil and #regions > 0 then
			for _, region in ipairs(regions) do
				if self:RegionContains(region, playerPos) then
					local exitD = self:RegionClampRay(region, origin, dir, result)
					if exitD < result then result = exitD end
				end
			end
		end
		-- (2) 블록 존(대시 불가지역) — 전용 DashBlock 그룹의 콜라이더 전체를 열거해 각각 방향성 클램프 후 min.
		-- Raycast는 첫(가장 가까운) 히트 1개만 반환 → 벽에 겹친 채 바깥으로 대시하면 벽만 보고(탈출 허용) 연결된
		-- 바닥은 놓쳐 관통하는 문제가 있어, 전체 열거로 모든 블록을 평가한다. 그룹 미등록이면 건너뜀(안전 폴백).
		local grp = CollisionGroups[_GameConstants.DashBlockGroup]
		if grp ~= nil then
			if self.blockColliderCacheMapName ~= map.Name then
				self.blockColliderCache = self:BuildBlockColliders(map, grp)
				self.blockColliderCacheMapName = map.Name
			end
			local cols = self.blockColliderCache
			if cols ~= nil and #cols > 0 then
				-- 접지 스텝오버: 원점 Y를 blockGrace만큼 올려 낮은 장애물 통과.
				local bOrigin = origin
				if blockGrace ~= 0 then bOrigin = Vector2(origin.x, origin.y + blockGrace) end
				for _, tc in ipairs(cols) do
					if isvalid(tc) and isvalid(tc.Entity) then
						local entry = self:BlockClampEntry(tc, bOrigin, dir, result, _GameConstants.DashWallMargin)
						if entry < result then result = entry end
					end
				end
			end
		end
		return result
	end

	method table BuildBlockColliders(Entity map, any grp)
		-- 맵의 DashBlock 그룹 TriggerComponent 목록 (맵별 캐시). 전체 열거 클램프용. grp.Id로 필터.
		local list = {}
		if map == nil or isvalid(map) == false then return list end
		local triggers = map:GetChildComponentsByTypeName("MOD.Core.TriggerComponent", true)
		if triggers ~= nil then
			for _, tcAny in ipairs(triggers) do
				---@type TriggerComponent
				local tc = tcAny
				if isvalid(tc) and tc.CollisionGroup ~= nil and tc.CollisionGroup.Id == grp.Id then
					table.insert(list, tc)
				end
			end
		end
		return list
	end

	method number SnapFootToBlock(Entity map, number footX, number footY, number maxSnap)
		-- 대시 도착 블록 스냅. 발에서 위로 maxSnap 지점부터 아래로 DashBlock 그룹 raycast해, 블록에 박혀 있으면
		-- OBB 진입점(=블록 윗면)으로 발을 올린다. 윗면이 발보다 위이고 깊이 ≤ maxSnap일 때만. (스텝오버로 넘은 낮은 블록 위에 안착)
		if map == nil or isvalid(map) == false then return footY end
		local grp = CollisionGroups[_GameConstants.DashBlockGroup]
		if grp == nil then return footY end
		local sim = _CollisionService:GetSimulator(map)
		if sim == nil then return footY end
		local rayOrigin = Vector2(footX, footY + maxSnap)
		local down = Vector2(0, -1)
		local hit = sim:Raycast(grp, rayOrigin, down, maxSnap)
		if hit == nil or isvalid(hit.Entity) == false then return footY end
		local entry = self:OBBRayEntry(hit, rayOrigin, down, maxSnap)
		-- entry==0 → 원점(footY+maxSnap)이 블록 내부 = 블록이 snap 범위보다 높이 솟음(상체까지 묻힘) → 스냅 거부.
		-- entry==maxSnap → 블록 윗면이 발 높이(묻힘 없음). 0<entry<maxSnap 일 때만 윗면 = origin-entry 로 올림.
		if entry > 0.0001 and entry < maxSnap then
			return (footY + maxSnap) - entry
		end
		return footY
	end

	method Vector2 ApplyFloorAimAssist(Vector2 dir, boolean onGround, number facingX)
		-- 접지 상태에서 너무 가파른 하향 조준이면 최소 각도(DashFloorMinSin)까지만 내려가도록 보정.
		-- (raycast 클램프가 발밑 바닥을 즉시 맞춰 대시 0거리 되는 것 방지 — 조작감) 공중/상향/수평/SideView(rb 없음→onGround=false)는 불변.
		-- dir: DirectionTo가 반환한 단위벡터. facingX: dir.x==0 동률일 때 평탄화 방향(±1).
		if onGround == false then return dir end
		local minY = -_GameConstants.DashFloorMinSin
		if dir.y >= minY then return dir end
		local sx = 0.0
		if dir.x > 0 then sx = 1.0 elseif dir.x < 0 then sx = -1.0 end
		if sx == 0.0 then
			if facingX < 0 then sx = -1.0 else sx = 1.0 end
			return Vector2(sx, 0)
		end
		local hx = math.sqrt(1.0 - minY * minY)
		return Vector2(sx * hx, minY)
	end

	method number SnapFootToFoothold(Entity map, number footX, number footY, number maxSnap)
		-- 대시 도착 발판 스냅(MapleTile). 발(footX,footY)에서 위로 maxSnap 지점부터 아래로 raycast해
		-- 발판 표면이 발보다 위(=발이 묻힘)이고 그 깊이가 maxSnap 이내면 발판 표면 Y를 반환(발판 위로 올림).
		-- 벽(수직 풋홀드)·범위 밖·발 아래 발판은 무시하고 footY 그대로. (도착지점 한정 호출)
		if map == nil or isvalid(map) == false then return footY end
		local fhc = map.FootholdComponent
		if isvalid(fhc) == false then return footY end
		local fh = fhc:Raycast(Vector2(footX, footY + maxSnap), Vector2(0, -1), maxSnap)
		if fh == nil then return footY end
		if fh:IsVertical() then return footY end
		local fy = fh:GetYByX(footX)
		if fy > footY and (fy - footY) <= maxSnap then
			return fy
		end
		return footY
	end

	@ExecSpace("ClientOnly")
	method Vector2 GetCursorWorldPos()
		-- 현재 마우스 커서의 월드 좌표 (클라 전용).
		return _UILogic:ScreenToWorldPosition(_InputService:GetCursorPosition())
	end

	@ExecSpace("ClientOnly")
	method Vector2 GetCursorWorldDir(Vector2 fromPos)
		-- fromPos에서 커서를 향하는 정규화 방향 벡터 (클라 전용).
		return self:DirectionTo(fromPos, self:GetCursorWorldPos())
	end

	@ExecSpace("ServerOnly")
	method void BroadcastEnemyAttack(Entity sourceEntity, number id, Vector2 center, number hw, number hh, number windup, number life, boolean parryable)
		-- 소스 적이 속한 맵의 모든 유저 클라에 공격 박스 통지(1인 1런 전제). DrawGizmo off면 미전송(클라 목록 미증가).
		if _GameConstants.DrawGizmo == false then return end
		if sourceEntity == nil or isvalid(sourceEntity) == false then return end
		local map = sourceEntity.CurrentMap
		if map == nil or isvalid(map) == false then return end
		local users = _UserService:GetUsersByMapComponent(map.MapComponent)
		if users == nil then return end
		for _, u in ipairs(users) do
			if isvalid(u) and u.PlayerComponent ~= nil then
				self:NotifyEnemyAttack(id, center, hw, hh, windup, life, parryable, u.PlayerComponent.UserId)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void BroadcastCancel(Entity mapEntity, number id)
		-- 공격 취소(패링/그로기 폐기) 기즈모 제거를 맵 유저 클라로 통지.
		if _GameConstants.DrawGizmo == false then return end
		if mapEntity == nil or isvalid(mapEntity) == false then return end
		local users = _UserService:GetUsersByMapComponent(mapEntity.MapComponent)
		if users == nil then return end
		for _, u in ipairs(users) do
			if isvalid(u) and u.PlayerComponent ~= nil then
				self:NotifyEnemyAttackCanceled(id, u.PlayerComponent.UserId)
			end
		end
	end

	@ExecSpace("Client")
	method void NotifyEnemyAttack(number id, Vector2 center, number hw, number hh, number windup, number life, boolean parryable)
		-- 클라 수신: 공격 박스 기즈모 등록(같은 id 있으면 교체). recvAt 스냅샷 후 CombatGizmo가 카운트다운.
		-- targetUserId는 @ExecSpace("Client") 라우팅용 암묵 인자로 호출부 '마지막'에 전달 — 선언 파라미터 아님(추가 금지).
		if self.clientEnemyAttacks == nil then self.clientEnemyAttacks = {} end
		for i = #self.clientEnemyAttacks, 1, -1 do
			if self.clientEnemyAttacks[i].id == id then table.remove(self.clientEnemyAttacks, i) end
		end
		table.insert(self.clientEnemyAttacks, {
			id = id,
			center = center,
			hw = hw,
			hh = hh,
			parryable = parryable,
			windup = windup,
			life = life,
			recvAt = _WallClock:Now(),
		})
	end

	@ExecSpace("Client")
	method void NotifyEnemyAttackCanceled(number id)
		-- 클라 수신: id 공격원 기즈모 제거(패링/폐기).
		if self.clientEnemyAttacks == nil then return end
		for i = #self.clientEnemyAttacks, 1, -1 do
			if self.clientEnemyAttacks[i].id == id then table.remove(self.clientEnemyAttacks, i) end
		end
	end

	@ExecSpace("ClientOnly")
	method any GetClientEnemyAttacks()
		-- 전투 기즈모가 폴링하는 클라 활성 공격 목록(없으면 생성).
		if self.clientEnemyAttacks == nil then self.clientEnemyAttacks = {} end
		return self.clientEnemyAttacks
	end

end
