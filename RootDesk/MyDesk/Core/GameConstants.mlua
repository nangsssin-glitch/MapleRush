	property string BossAttackClip = "90c5456e2a8a45478df02500797a9afd"

	property string BossSkillClip = "b9345875a8134c7c9a1b6aed8551d808"

	property string BossGroggyClip = "90fee9416184420a9796a679751d1ec5"

	property string TelegraphModelId = "telegraphgauge"

	property string TelegraphFramePrefix = "TgFrame"

	property string TelegraphFillPrefix = "TgFill"

	property integer TelegraphPoolSize = 8

	property number TelegraphFrameAlpha = 0.22

	property number TelegraphFillAlpha = 0.62

	property number TelegraphMinFill = 0.05

	property Color TelegraphColorYellow = Color(1.0, 0.85, 0.15, 1.0)

	property Color TelegraphColorRed = Color(1.0, 0.2, 0.15, 1.0)

	property number TelegraphPxBaseWorld = 0.16

	-- ========== 보스 패턴 수치 (boss_design_doc §3 — 밸런싱 조정용. windup=시전(예고)시간 / Cd=후딜쿨 / BoxHW·HH=히트박스 반폭·반높이) ==========
	-- 엘리쟈(오르비스): O1 암흑구체(원거리 3부채꼴) / O2 암흑강림(추적 광역) / O3 그림자쐐기(보스 좌우 2광역)
	property number BossO1Windup = 0.6
	property number BossO1Cd = 1.0
	property number BossO2Windup = 1.0
	property number BossO2Cd = 2.5
	property number BossO2BoxHW = 2.0
	property number BossO2BoxHH = 1.5
	property number BossO3Windup = 1.1
	property number BossO3Cd = 2.8
	property number BossO3BoxHW = 2.0
	property number BossO3BoxHH = 1.5
	-- 스노우맨(엘나스): E1 눈주먹(근접) / E2 고드름(원거리 단발) / E3 블리자드(대형 광역)
	property number BossE1Windup = 0.9
	property number BossE1Cd = 1.2
	property number BossE1BoxHW = 1.8
	property number BossE1BoxHH = 1.0
	property number BossE2Windup = 0.7
	property number BossE2Cd = 1.1
	property number BossE3Windup = 1.1
	property number BossE3Cd = 2.8
	property number BossE3BoxHW = 3.5
	property number BossE3BoxHH = 2.0
	-- 자쿰(폐광): Z1 팔후려치기(근접 좌/우=전방) / Z2 박수레이저(수평 단발) / Z3 용암분출(다지점)
	property number BossZ1Windup = 0.7
	property number BossZ1Cd = 1.0
	property number BossZ1BoxHW = 2.0
	property number BossZ1BoxHH = 1.0
	property number BossZ2Windup = 0.8
	property number BossZ2Cd = 1.0
	-- P-Z2 박수 레이저 빔 비주얼(연출 전용 — 실제 판정은 발사되는 투사체). Clip=fieldskill 가로 레이저.
	-- ScaleX=빔 길이 / ScaleY=빔 두께 / OffsetX=보스 발사방향 중심 이동(월드유닛). 전부 눈 튜닝용.
	property string BossZakumBeamClip = "3a2ea8cf59ad4372b6982266be675704"
	property number BossZakumBeamScaleX = 0.7
	property number BossZakumBeamScaleY = 0.7
	property number BossZakumBeamOffsetX = 4.0
	property number BossZ3Windup = 1.0
	property number BossZ3Cd = 2.5
	property number BossZ3BoxHW = 1.5
	property number BossZ3BoxHH = 1.5
	property integer BossZ3Points = 3
	-- 좌우 쐐기(O3) 보스 발밑 안전지대 반폭(박스 중심 오프셋 = 이 값 + BoxHW). 자쿰 용암 랜덤 가로 분포 반경(보스중심 ±).
	property number BossSidesSafeHalf = 1.0
	property number BossMultiSpreadX = 6.0
	-- 거리밴드 경계(가로거리 d, §1.6): d≤Close=CLOSE(광역>근접>원거리) / d≤Mid=MID(광역>원거리) / 그외=FAR(원거리만).
	property number BossBandClose = 4.0
	property number BossBandMid = 7.5

	method integer NormalStagesForFloor(integer floor)
		-- 층별 일반 스테이지 진행 횟수: 4 + 1*(층수-1) (stage_design_doc §2.2.3)
		return self.Floor1NormalStages + (floor - 1)
	end

	method number ClampMeso(number meso)
		-- 메소 캡(uint max) 초과 시 클램프 (player_design_doc §6.5)
		if meso > self.MesoCap then return self.MesoCap end
		if meso < 0 then return 0 end
		return meso
	end

	method string MapIdForStage(string stageType)
		-- 스테이지 타입 → 맵 id. 보스(map03) / 상점(map04) / 일반(map02).
		if stageType == "boss" then return self.MapBoss end
		if stageType == "shop" then return self.MapShop end
		return self.MapNormal
	end

	method string MapForTheme(string theme)
		-- 일반 스테이지 맵 = 선택된 테마가 결정 (접두사). Hierarchy name 그대로 반환
		-- (MoveToMapPosition / cm.Name / /maps/ 경로 전부 name 사용 — 소문자 entry-id 쓰면 MR-R식 키 불일치).
		if theme == "orbis" then return "OrbisLevel" end
		if theme == "elnath" then return "ElnathLevel" end
		if theme == "deepmine" then return "DeepMineLevel" end
		return "ElnathLevel"
	end

	method string BossMapForTheme(string theme)
		-- 보스 스테이지 맵 = 테마 레벨맵 이름 + "_Boss" 규약 (예: DeepMineLevel_Boss).
		-- 파일명==루트 Hierarchy name 검증됨(세 테마 전부 TileMapMode=0). name 그대로 반환.
		return self:MapForTheme(theme) .. "_Boss"
	end

end