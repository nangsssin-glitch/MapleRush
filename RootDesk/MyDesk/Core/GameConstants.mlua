	-- 엔티티 피격(hurtbox) 박스 반폭/반높이 (원→박스 통일). 캐릭터형(세로로 김). 기즈모도 동일 치수 사용.
	-- 플레이어 박스 중심 = pos.y + 0.5(PlayerCenterYOffset과 동일). 적 박스 중심 = transform raw 좌표.
	property number PlayerHboxHW = 0.35
	property number PlayerHboxHH = 0.6
	property number EnemyHboxHW = 0.45
	property number EnemyHboxHH = 0.55

	property number MeleeEnemyHP = 30.0

	property number RangedEnemyHP = 20.0

	property number EnemyMoveSpeed = 1.5

	-- 스폰 시 몬스터 Y를 이만큼 살짝 들어올려 스폰(방어적 보정). MapleTile foothold는 위에서만 잡으므로,
	-- authoring 마커가 의도한 발판보다 미세하게(관측상 ~0.08) 아래로 박혀 있으면 통과→낙하한다.
	-- 이 리프트로 항상 발판 위에서 스폰→중력이 올바른 발판에 안착. 모든 테마맵/미래 authoring 공통 적용.
	property number SpawnYLift = 0.15

	property number BossHP = 500.0

	property number GroggyGaugeRatio = 0.2

	property number GroggyDecayPerSec = 0.02

	property number BossPatternDelay = 1.5

	property number MesoCap = 4294967295.0

	property integer ScoreCap = 65535

	property integer MesoPerNormalClear = 10

	property integer MesoPerBossClear = 150

